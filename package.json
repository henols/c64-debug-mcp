{
  "name": "vicemcp-workspace",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build --workspace @vicemcp/vice-debug-mcp && VICE_DEBUG_MCP_ENTRYPOINT=\"$PWD/packages/vice-debug-mcp/dist/stdio.js\" mastra dev",
    "build": "npm run build --workspace @vicemcp/vice-debug-mcp",
    "check": "npm run check --workspace @vicemcp/vice-debug-mcp"
  },
  "devDependencies": {
    "mastra": "^1.3.14"
  }
}
